-
-void HalTiltSensor::update(const uint8_t mode, const uint8_t orientation, const bool inReader) {
-  if (!_available) {
-    return;
-  }
-
-  // State machine: wake up or sleep based on the enabled flag
-  if ((mode != CrossPointTiltPageTurn::TILT_OFF) && !_isAwake) {
-    _isAwake = wake();
