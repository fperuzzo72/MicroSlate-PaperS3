+// ---------------------------------------------------------------------------
+// Permanent header/footer chrome (PaperS3 touch substitutes — see HalGPIO).
+// Reserved on every screen at a fixed height (gpio.getHeaderHeight() /
+// getFooterHeight(), set once in main.cpp setup()); screens position their
+// content between the two rather than drawing their own header row.
+//
+// Header, 4 quarters:  Home | KB + WiFi status | Battery | Sleep
+// Footer, 4 quarters:  Back | Confirm | Up | Down
+// ---------------------------------------------------------------------------
+
+// Center a label horizontally within quarter `quarterIdx` (0-3) of a
+// `barH`-tall bar starting at `barTop`, vertically centered within it.
+static void drawChromeLabel(GfxRenderer& r, int quarterIdx, int barTop, int barH, int sw,
+                            const char* label, bool tc, int lineOffset = 0) {
+  int quarterW = sw / 4;
+  int cx = quarterIdx * quarterW + quarterW / 2;
+  int tw = r.getTextAdvanceX(FONT_SMALL, label);
+  int x = cx - tw / 2;
+  if (x < quarterIdx * quarterW + 2) x = quarterIdx * quarterW + 2;
+  int y = barTop + barH / 2 - 6 + lineOffset;
+  drawClippedText(r, FONT_SMALL, x, y, label, quarterW - 4, tc);
+}
+
+static void drawChromeHeader(GfxRenderer& renderer, HalGPIO& gpio) {
+  int sw = renderer.getScreenWidth();
+  int headerH = gpio.getHeaderHeight();
+  if (headerH <= 0) return;
+  bool tc = !darkMode;
+  int quarterW = sw / 4;
+
+  for (int i = 1; i < 4; i++) {
+    clippedLine(renderer, i * quarterW, 4, i * quarterW, headerH - 4, tc);
+  }
+  clippedLine(renderer, 0, headerH, sw, headerH, tc);
+
+  // Q1: Home
+  drawChromeLabel(renderer, 0, 0, headerH, sw, "Home", tc);
+
+  // Q2: keyboard status (top line) + WiFi activity (bottom line, only while
+  // wifiSyncActive — the firmware only turns the radio on during PC sync,
+  // there is no persistent "connected to a network" state otherwise).
+  const char* kbStatus = "KB --";
+  switch (getConnectionState()) {
+    case BLEState::CONNECTED:    kbStatus = "KB OK"; break;
+    case BLEState::SCANNING:     kbStatus = "KB scan"; break;
+    case BLEState::CONNECTING:   kbStatus = "KB conn"; break;
+    case BLEState::DISCONNECTED: kbStatus = "KB --"; break;
+  }
+  drawChromeLabel(renderer, 1, 0, headerH, sw, kbStatus, tc, -10);
+  if (isWifiSyncActive()) {
+    drawChromeLabel(renderer, 1, 0, headerH, sw, "WiFi", tc, 10);
+  }
+
+  // Q3: battery percentage
+  int pct = gpio.getBatteryPercentage();
+  char battBuf[8];
+  snprintf(battBuf, sizeof(battBuf), "%d%%", pct);
+  drawChromeLabel(renderer, 2, 0, headerH, sw, battBuf, tc);
+
+  // Q4: Sleep
+  drawChromeLabel(renderer, 3, 0, headerH, sw, "Sleep", tc);
+}
+
+// q3Label/q4Label override the Up/Down labels — used by screens that
+// repurpose those two zones for a different pair of actions (e.g. the
+// Bluetooth screen uses them for Scan/Disconnect instead of list Up/Down).
+// The underlying virtual buttons produced by tapping those zones are still
+// BTN_UP/BTN_DOWN (HalGPIO has no concept of "current screen"); it's up to
+// the caller's button-handling code to interpret them accordingly.
+static void drawChromeFooter(GfxRenderer& renderer, HalGPIO& gpio,
+                             const char* q3Label = "Up", const char* q4Label = "Down") {
+  int sw = renderer.getScreenWidth();
+  int sh = renderer.getScreenHeight();
+  int footerH = gpio.getFooterHeight();
+  if (footerH <= 0) return;
+  bool tc = !darkMode;
+  int barTop = sh - footerH;
+  int quarterW = sw / 4;
+
+  clippedLine(renderer, 0, barTop, sw, barTop, tc);
+  for (int i = 1; i < 4; i++) {
+    clippedLine(renderer, i * quarterW, barTop + 4, i * quarterW, sh - 4, tc);
+  }
+
+  drawChromeLabel(renderer, 0, barTop, footerH, sw, "Back", tc);
+  drawChromeLabel(renderer, 1, barTop, footerH, sw, "Confirm", tc);
+  drawChromeLabel(renderer, 2, barTop, footerH, sw, q3Label, tc);
+  drawChromeLabel(renderer, 3, barTop, footerH, sw, q4Label, tc);
+}
