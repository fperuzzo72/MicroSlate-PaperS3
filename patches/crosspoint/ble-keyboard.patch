diff --git a/src/activities/notes/ble/KeyboardPairingActivity.cpp b/src/activities/notes/ble/KeyboardPairingActivity.cpp
new file mode 100644
index 0000000..ca83dfa
--- /dev/null
+++ b/src/activities/notes/ble/KeyboardPairingActivity.cpp
@@ -0,0 +1,140 @@
+#include "KeyboardPairingActivity.h"
+
+#include <GfxRenderer.h>
+
+#include <cstdio>
+
+#include "ble_keyboard.h"
+#include "components/UITheme.h"
+#include "fontIds.h"
+
+void KeyboardPairingActivity::onEnter() {
+  Activity::onEnter();
+  bleSetup();  // idempotent — initializes NimBLE on first use only
+  startDeviceScan();
+  selectorIndex = 0;
+  lastShownPasskey = 0;
+  lastShownDeviceCount = -1;
+  lastShownState = -1;
+  requestUpdateAndWait();
+}
+
+void KeyboardPairingActivity::onExit() {
+  stopDeviceScan();
+  Activity::onExit();
+}
+
+void KeyboardPairingActivity::loop() {
+  bleLoop();
+
+  const int deviceCount = getDiscoveredDeviceCount();
+
+  buttonNavigator.onNext([this, deviceCount] {
+    if (deviceCount > 0) {
+      selectorIndex = ButtonNavigator::nextIndex(selectorIndex, deviceCount);
+      requestUpdate();
+    }
+  });
+  buttonNavigator.onPrevious([this, deviceCount] {
+    if (deviceCount > 0) {
+      selectorIndex = ButtonNavigator::previousIndex(selectorIndex, deviceCount);
+      requestUpdate();
+    }
+  });
+
+  if (mappedInput.wasReleased(MappedInputManager::Button::Confirm) && deviceCount > 0) {
+    if (selectorIndex < deviceCount) {
+      connectToDevice(selectorIndex);
+      requestUpdate();
+    }
+  }
+
+  if (mappedInput.wasPressed(MappedInputManager::Button::Back)) {
+    finish();
+    return;
+  }
+
+  // Poll for async state changes (scan results arriving, passkey appearing,
+  // connection completing) — redraw only when something actually changed,
+  // at most twice a second, to respect the e-ink panel.
+  if (millis() - lastPollMs > 500) {
+    lastPollMs = millis();
+    const uint32_t passkey = getCurrentPasskey();
+    const int state = static_cast<int>(getConnectionState());
+    if (passkey != lastShownPasskey || deviceCount != lastShownDeviceCount || state != lastShownState) {
+      requestUpdate();
+    }
+  }
+}
+
+void KeyboardPairingActivity::render(RenderLock&&) {
+  renderer.clearScreen();
+
+  const auto& metrics = UITheme::getInstance().getMetrics();
+  const auto pageWidth = renderer.getScreenWidth();
+  const auto pageHeight = renderer.getScreenHeight();
+
+  GUI.drawHeader(renderer, Rect{0, metrics.topPadding, pageWidth, metrics.headerHeight}, "Pair keyboard");
+
+  int y = metrics.topPadding + metrics.headerHeight + metrics.verticalSpacing;
+  const int lineHeight = renderer.getLineHeight(UI_10_FONT_ID);
+  const int x = metrics.contentSidePadding;
+
+  // Connection state line
+  const char* stateText = "";
+  switch (getConnectionState()) {
+    case BLEState::CONNECTED: stateText = "Keyboard connected"; break;
+    case BLEState::CONNECTING: stateText = "Connecting..."; break;
+    case BLEState::SCANNING: stateText = "Scanning for keyboards..."; break;
+    case BLEState::DISCONNECTED: stateText = "Not connected"; break;
+  }
+  renderer.drawText(UI_10_FONT_ID, x, y, stateText);
+  y += lineHeight + metrics.verticalSpacing;
+
+  // Passkey, when the keyboard asks for one
+  const uint32_t passkey = getCurrentPasskey();
+  lastShownPasskey = passkey;
+  lastShownDeviceCount = getDiscoveredDeviceCount();
+  lastShownState = static_cast<int>(getConnectionState());
+  if (passkey > 0) {
+    char passkeyStr[16];
+    snprintf(passkeyStr, sizeof(passkeyStr), "%06lu", static_cast<unsigned long>(passkey));
+    renderer.drawText(UI_12_FONT_ID, x, y, "Type this code on the keyboard,", true);
+    y += lineHeight + 2;
+    renderer.drawText(UI_12_FONT_ID, x, y, "then press Enter:", true);
+    y += lineHeight + metrics.verticalSpacing;
+    renderer.drawText(UI_12_FONT_ID, x, y, passkeyStr, true, EpdFontFamily::BOLD);
+    y += lineHeight + metrics.verticalSpacing;
+  }
+
+  // Device list
+  const int deviceCount = getDiscoveredDeviceCount();
+  if (deviceCount > 0) {
+    BleDeviceInfo* devices = getDiscoveredDevices();
+    const int listBottom = pageHeight - metrics.buttonHintsHeight - metrics.verticalSpacing;
+    for (int i = 0; i < deviceCount; i++) {
+      if (y + lineHeight > listBottom) break;
+
+      const char* name = devices[i].name.empty() ? devices[i].address.c_str() : devices[i].name.c_str();
+      char row[80];
+      snprintf(row, sizeof(row), "%s  (%d dBm)", name, devices[i].rssi);
+
+      if (i == selectorIndex) {
+        renderer.fillRect(0, y - 2, pageWidth, lineHeight + 4);
+        renderer.drawText(UI_10_FONT_ID, x, y, row, false);
+      } else {
+        renderer.drawText(UI_10_FONT_ID, x, y, row);
+      }
+      y += lineHeight + 6;
+    }
+  } else if (passkey == 0) {
+    renderer.drawText(UI_10_FONT_ID, x, y, "No keyboards found yet.");
+    y += lineHeight;
+    renderer.drawText(UI_10_FONT_ID, x, y, "Put the keyboard in pairing mode.");
+  }
+
+  const auto labels = mappedInput.mapLabels("Back", deviceCount > 0 ? "Connect" : "", "", "");
+  GUI.drawButtonHints(renderer, labels.btn1, labels.btn2, labels.btn3, labels.btn4);
+
+  renderer.displayBuffer();
+}
