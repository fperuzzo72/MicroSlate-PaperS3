diff --git a/src/activities/notes/ble/KeyQueue.cpp b/src/activities/notes/ble/KeyQueue.cpp
new file mode 100644
index 0000000..573d2f3
--- /dev/null
+++ b/src/activities/notes/ble/KeyQueue.cpp
@@ -0,0 +1,48 @@
+#include "KeyQueue.h"
+
+#include <freertos/FreeRTOS.h>
+
+// MicroSlate's ring buffer, with one adaptation: the original guarded with
+// noInterrupts()/interrupts(), which on ESP32 doesn't protect against the
+// *other core* — and NimBLE's notify callback (the producer) runs on a
+// separate FreeRTOS task that may be on the other core. A spinlock critical
+// section protects both cores.
+static KeyEvent inputQueue[INPUT_QUEUE_SIZE];
+static int queueHead = 0;
+static int queueTail = 0;
+static volatile bool queueFull = false;
+static portMUX_TYPE queueMux = portMUX_INITIALIZER_UNLOCKED;
+
+void enqueueKeyEvent(uint8_t keyCode, uint8_t modifiers, bool pressed) {
+  taskENTER_CRITICAL(&queueMux);
+  if (!queueFull) {
+    inputQueue[queueHead].keyCode = keyCode;
+    inputQueue[queueHead].modifiers = modifiers;
+    inputQueue[queueHead].pressed = pressed;
+    queueHead = (queueHead + 1) % INPUT_QUEUE_SIZE;
+    if (queueHead == queueTail) queueFull = true;
+  }
+  taskEXIT_CRITICAL(&queueMux);
+}
+
+bool dequeueKeyEvent(KeyEvent& out) {
+  bool got = false;
+  taskENTER_CRITICAL(&queueMux);
+  const bool empty = (queueHead == queueTail) && !queueFull;
+  if (!empty) {
+    out = inputQueue[queueTail];
+    queueTail = (queueTail + 1) % INPUT_QUEUE_SIZE;
+    queueFull = false;
+    got = true;
+  }
+  taskEXIT_CRITICAL(&queueMux);
+  return got;
+}
+
+void clearKeyQueue() {
+  taskENTER_CRITICAL(&queueMux);
+  queueHead = 0;
+  queueTail = 0;
+  queueFull = false;
+  taskEXIT_CRITICAL(&queueMux);
+}
