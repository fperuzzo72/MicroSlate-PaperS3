+
+// Append an escaped JSON string value (no surrounding quotes) — used by
+// writeBleBackup() to build the backup JSON by hand.
+static inline void jsonAppendStr(char* buf, size_t bufSize, const char* src) {
+  size_t pos = strlen(buf);
+  while (*src && pos < bufSize - 2) {
+    if (*src == '"' || *src == '\\') buf[pos++] = '\\';
+    buf[pos++] = *src++;
+  }
+  buf[pos] = '\0';
+}
+
+// writeBleBackup() in ble_keyboard.cpp calls SdMan.exists()/mkdir() directly
+// (MicroSlate's SDCardManager singleton) instead of going through
+// sdWriteFile()'s own directory-creation. A tiny compatibility shim so that
+// call site works unmodified against HalStorage.
+struct SdManCompat {
+  bool exists(const char* path) { return Storage.exists(path); }
+  bool mkdir(const char* path) { return Storage.ensureDirectoryExists(path); }
+};
+static SdManCompat SdMan;
