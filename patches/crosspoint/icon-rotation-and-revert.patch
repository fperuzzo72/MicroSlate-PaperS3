+namespace {
+// Icons are packed 1bpp, MSB-first, row-major (bit=0 -> black, bit=1 ->
+// transparent — see HalDisplay::drawImageTransparent). Largest icon in use
+// today is 32x32 = 128 bytes; bump this if a larger one gets added.
+constexpr size_t kMaxIconBitmapBytes = 256;
+
+// Rotate a packed 1bpp bitmap 180°. Needed because drawImageTransparent()
+// blits pixel data exactly as stored — only the *position* it's placed at
+// is orientation-aware (via rotateCoordinates()), not the pixel content
+// itself. Portrait and PortraitInverted are 180° different mappings onto
+// the physical (landscape) panel; these icon assets were authored assuming
+// the Portrait mapping, so under PortraitInverted they need their content
+// rotated to still read right-side-up.
+bool rotateBitmap180(const uint8_t* src, uint8_t* dst, int width, int height) {
+  const int rowBytes = width / 8;
+  const size_t totalBytes = static_cast<size_t>(rowBytes) * height;
+  if (rowBytes == 0 || totalBytes > kMaxIconBitmapBytes) return false;
+
+  memset(dst, 0xFF, totalBytes);  // 1 = transparent by default
+
+  for (int y = 0; y < height; y++) {
+    for (int x = 0; x < width; x++) {
+      const int srcByteIdx = y * rowBytes + x / 8;
+      const int srcBit = 7 - (x % 8);
+      const uint8_t srcByte = src[srcByteIdx];
+      const bool isBlack = !((srcByte >> srcBit) & 1);
+      if (!isBlack) continue;
+
+      const int dx = width - 1 - x;
+      const int dy = height - 1 - y;
+      const int dstByteIdx = dy * rowBytes + dx / 8;
+      const int dstBit = 7 - (dx % 8);
+      dst[dstByteIdx] &= ~(1 << dstBit);
+    }
+  }
+  return true;
+}
+}  // namespace
+
