@@ -634,12 +673,19 @@ void GfxRenderer::drawIcon(const uint8_t bitmap[], const int x, const int y, con
   int rotatedX = 0;
   int rotatedY = 0;
   rotateCoordinates(orientation, x, y, &rotatedX, &rotatedY);
+
+  const uint8_t* bitsToDraw = bitmap;
+  uint8_t rotatedBitmap[kMaxIconBitmapBytes];
+
   switch (orientation) {
     case Portrait:
       rotatedY = rotatedY - height;
       break;
     case PortraitInverted:
       rotatedX = rotatedX - width;
+      if (rotateBitmap180(bitmap, rotatedBitmap, width, height)) {
+        bitsToDraw = rotatedBitmap;
+      }
       break;
     case LandscapeClockwise:
       rotatedY = rotatedY - height;
@@ -648,7 +694,7 @@ void GfxRenderer::drawIcon(const uint8_t bitmap[], const int x, const int y, con
     case LandscapeCounterClockwise:
       break;
   }
-  display.drawImageTransparent(bitmap, rotatedX, rotatedY, width, height);
+  display.drawImageTransparent(bitsToDraw, rotatedX, rotatedY, width, height);
 }
 
