+#pragma once
+#include <cstddef>
+
+#include "NoteEditor.h"
+
+// MicroSlate's note file management (src/file_manager.cpp) ported onto
+// CrossPoint's HalStorage. Notes are plain .txt files in /notes on the SD
+// card — same on-disk format as standalone MicroSlate on the X4 (first line
+// used as the display title), so a card moved between devices keeps working.
+class NoteStore {
+ public:
+  static constexpr int kMaxFiles = 50;
+  static constexpr const char* kNotesDir = "/notes";
+
+  struct FileInfo {
+    char filename[NoteEditor::kMaxFilenameLen];
+    char title[NoteEditor::kMaxTitleLen];
+  };
+
+  // Ensure /notes exists; returns false if the SD card isn't usable.
+  bool begin();
+  void refreshFileList();
+  int fileCount() const { return count; }
+  const FileInfo& file(int index) const { return files[index]; }
+
+  // Load note contents into the editor. Returns false on read failure.
+  bool loadFile(const char* filename, NoteEditor& editor);
+  // Save the editor's buffer to its current file (write-to-temp + rename,
+  // same crash-safety pattern as MicroSlate's saveCurrentFile).
+  bool saveCurrentFile(NoteEditor& editor);
+  // Start a new note in the editor with a unique filename (not yet on disk
+  // until first save).
+  void createNewFile(NoteEditor& editor);
+  bool deleteFile(const char* filename);
+
+ private:
+  void deriveTitleFromContent(const char* buf, size_t len, char* out, int maxLen) const;
+
+  FileInfo files[kMaxFiles];
+  int count = 0;
+};
