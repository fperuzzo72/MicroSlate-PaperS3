diff --git a/src/activities/notes/NotesActivity.cpp b/src/activities/notes/NotesActivity.cpp
new file mode 100644
index 0000000..2e32cee
--- /dev/null
+++ b/src/activities/notes/NotesActivity.cpp
@@ -0,0 +1,42 @@
+#include "NotesActivity.h"
+
+#include <GfxRenderer.h>
+
+#include "components/UITheme.h"
+#include "fontIds.h"
+
+// TODO(microslate-port): this is a scaffold, not the ported editor. Replace
+// loop()/render() with the real MicroSlate note editor (text buffer, file
+// browser for notes, keyboard input handling) once ported. The class name,
+// constructor, and the HomeActivity/ActivityManager wiring around it are
+// meant to stay as-is — only the body changes.
+
+void NotesActivity::loop() {
+  if (mappedInput.wasPressed(MappedInputManager::Button::Back)) {
+    onGoHome();
+  }
+}
+
+void NotesActivity::render(RenderLock&&) {
+  renderer.clearScreen();
+
+  const auto& metrics = UITheme::getInstance().getMetrics();
+  const auto pageWidth = renderer.getScreenWidth();
+
+  GUI.drawHeader(renderer, Rect{0, metrics.topPadding, pageWidth, metrics.headerHeight}, "Notes");
+
+  const auto lineHeight = renderer.getLineHeight(UI_10_FONT_ID);
+  int y = metrics.topPadding + metrics.headerHeight + metrics.verticalSpacing * 3;
+  const auto x = metrics.contentSidePadding;
+
+  renderer.drawText(UI_10_FONT_ID, x, y, "MicroSlate note editor — not ported yet.");
+  y += lineHeight * 2;
+  renderer.drawText(UI_10_FONT_ID, x, y, "This screen is a placeholder so the");
+  y += lineHeight;
+  renderer.drawText(UI_10_FONT_ID, x, y, "menu structure exists ahead of the port.");
+
+  const auto labels = mappedInput.mapLabels("Back", "", "", "");
+  GUI.drawButtonHints(renderer, labels.btn1, labels.btn2, labels.btn3, labels.btn4);
+
+  renderer.displayBuffer();
+}
diff --git a/src/activities/notes/NotesActivity.h b/src/activities/notes/NotesActivity.h
new file mode 100644
index 0000000..c8dd71a
--- /dev/null
+++ b/src/activities/notes/NotesActivity.h
@@ -0,0 +1,16 @@
+#pragma once
+#include "../Activity.h"
+
+// Placeholder for the ported MicroSlate note editor. Scaffolding only —
+// grouped under "MicroSlate" in HomeActivity's menu, reachable, and returns
+// home on Back — but doesn't edit anything yet. The real port (text buffer,
+// file browser for notes, the touch/keyboard input handling we already
+// built for standalone MicroSlate) replaces this render()/loop() body in
+// place; the class and the menu wiring around it don't need to change.
+class NotesActivity final : public Activity {
+ public:
+  explicit NotesActivity(GfxRenderer& renderer, MappedInputManager& mappedInput)
+      : Activity("Notes", renderer, mappedInput) {}
+  void loop() override;
+  void render(RenderLock&&) override;
+};
